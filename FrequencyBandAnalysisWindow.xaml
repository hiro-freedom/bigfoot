<Window x:Class="bigfoot.FrequencyBandAnalysisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Frequency Band Analysis"
        Width="980"
        Height="640"
        MinWidth="860"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="#111827">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Frequency Band Analysis"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#F9FAFB" />
            <TextBlock Margin="0,8,0,0"
                       Text="Current phase target: offline, segment-based workflow for per-game HighPass/LowPass recommendations."
                       FontSize="13"
                       Foreground="#9CA3AF"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#1F2937"
                    BorderBrush="#374151"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            x:Name="OpenFileButton"
                            Width="110"
                            Height="34"
                            Content="Open WAV"
                            Click="OnOpenFileClick" />

                    <TextBlock Grid.Column="2"
                               x:Name="FilePathText"
                               VerticalAlignment="Center"
                               Text="No file loaded"
                               Foreground="#D1D5DB"
                               TextTrimming="CharacterEllipsis" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Background="#1F2937"
                    BorderBrush="#374151"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            x:Name="PlayPauseButton"
                            Width="90"
                            Height="34"
                            Content="Play"
                            IsEnabled="False"
                            Click="OnPlayPauseClick" />

                    <Button Grid.Column="2"
                            x:Name="StopButton"
                            Width="90"
                            Height="34"
                            Content="Stop"
                            IsEnabled="False"
                            Click="OnStopClick" />

                    <TextBlock Grid.Column="4"
                               x:Name="CurrentTimeText"
                               VerticalAlignment="Center"
                               Text="00:00"
                               Foreground="#E5E7EB" />

                    <Slider Grid.Column="6"
                            x:Name="TimelineSlider"
                            Minimum="0"
                            Maximum="1"
                            Value="0"
                            IsEnabled="False"
                            ValueChanged="OnTimelineValueChanged"
                            PreviewMouseLeftButtonDown="OnTimelineMouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="OnTimelineMouseLeftButtonUp"
                            LostMouseCapture="OnTimelineLostMouseCapture" />

                    <TextBlock Grid.Column="8"
                               x:Name="DurationText"
                               VerticalAlignment="Center"
                               Text="00:00"
                               Foreground="#9CA3AF" />
                </Grid>
            </Border>

            <Border Grid.Row="4"
                    Background="#0F172A"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10">
                <Grid>
                    <Canvas x:Name="WaveformCanvas"
                            Background="#0B1220"
                            SizeChanged="OnWaveformCanvasSizeChanged" />

                    <TextBlock Margin="12"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left"
                               Text="Waveform preview"
                               Foreground="#64748B" />
                </Grid>
            </Border>
        </Grid>

        <DockPanel Grid.Row="4"
                   LastChildFill="False">
            <TextBlock DockPanel.Dock="Left"
                       x:Name="StatusText"
                       VerticalAlignment="Center"
                       Text="Status: Ready"
                       Foreground="#9CA3AF" />
            <Button DockPanel.Dock="Right"
                    Width="96"
                    Height="34"
                    Margin="12,0,0,0"
                    Content="Close"
                    Click="OnCloseClick" />
        </DockPanel>
    </Grid>
</Window>
